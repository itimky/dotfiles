export COMPLETION_WAITING_DOTS="true"
plugins=(
	git
	docker
	docker-compose
)
source $ZSH/oh-my-zsh.sh

[[ -n "$commands[mise]" ]] && eval "$(mise activate zsh)"

_load_deferred_completions_once() {
	add-zsh-hook -d preexec _load_deferred_completions_once

	[[ -n "$commands[flux]" ]] && source <(flux completion zsh)
	[[ -n "$commands[mise]" ]] && source <(mise completion zsh)
	[[ -n "$commands[pnpm]" ]] && source <(pnpm completion zsh)
	[[ -n "$commands[terraform]" ]] && complete -o nospace -C "${commands[terraform]}" terraform

	unset -f _load_deferred_completions_once
}

# Defer optional tool completions until the first executed command.
if [[ -o interactive ]]; then
	add-zsh-hook preexec _load_deferred_completions_once
else
	_load_deferred_completions_once
fi

# Initialize completions after all fpath modifications are complete
autoload -Uz compinit && compinit

wire-dotfiles-devcontainer() {
	make -f ${DOTFILES}/devcontainer/Makefile wire-local
}

if [[ $OSTYPE == linux* ]] || ! command -v brew >/dev/null 2>&1; then
	return
fi

HOMEBREW_PREFIX=$(brew --prefix)
for _gnu_pkg (coreutils gnu-sed grep gnu-tar gawk findutils make); do
	path=($HOMEBREW_PREFIX/opt/$_gnu_pkg/libexec/gnubin $path)
	manpath=($HOMEBREW_PREFIX/opt/$_gnu_pkg/libexec/gnuman $manpath)
done
unset _gnu_pkg

path=($HOMEBREW_PREFIX/opt/vim/bin $path)
