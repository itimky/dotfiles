{
  "[csharp][github-actions-workflow][javascript][json][jsonc][markdown][sql][typescript][typescriptreact][xml][yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "chatgpt.commentCodeLensEnabled": false,
  "chatgpt.composerEnterBehavior": "cmdIfMultiline",
  "database-client.autoSync": true,
  "database-client.telemetry.usesOnlineServices": false,
  "editor.autoIndentOnPasteWithinString": false,
  "editor.fontSize": 13,
  "editor.fontVariations": false,
  "editor.fontWeight": "normal",
  "editor.formatOnSave": true,
  "editor.inlineSuggest.edits.renderSideBySide": "never",
  "editor.inlineSuggest.edits.showLongDistanceHint": false,
  "editor.inlineSuggest.experimental.emptyResponseInformation": false,
  "editor.inlineSuggest.showToolbar": "never",
  "editor.inlineSuggest.syntaxHighlightingEnabled": false,
  "editor.minimap.enabled": false,
  "editor.pasteAs.enabled": false,
  "editor.pasteAs.showPasteSelector": "never",
  "editor.renderLineHighlight": "none",
  "editor.screenReaderAnnounceInlineSuggestion": false,
  "editor.tabSize": 2,
  "editor.wordBasedSuggestions": "off",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "files.readonlyFromPermissions": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "latex-workshop.latex.outDir": "../out",
  "terraform.codelens.referenceCount": true,
  "vitest.configSearchPatternExclude": "{obsolete/**,**/node_modules/**,**/vendor/**,**/.*/**,**/*.d.ts}",
  "vitest.configSearchPatternInclude": "**/vitest.config*.{ts,js,mjs,cjs,cts,mts}",
  "vitest.logLevel": "info",
  "window.autoDetectColorScheme": true,
  "window.zoomLevel": 1,
  "workbench.colorTheme": "Silver Dark",
  "workbench.preferredHighContrastColorTheme": "Silver Dark",
  "github.copilot.enable": {
    "markdown": true
  }
}
