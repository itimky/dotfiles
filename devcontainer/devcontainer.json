{
  "name": "dotfiles",
  "dockerComposeFile": "docker-compose.yaml",
  "service": "devcontainer",
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "openai.chatgpt",
        "vitest.explorer"
      ]
    }
  },
  "workspaceFolder": "/home/vscode/worktree",
  "containerEnv": {
    "DOTFILES": "/mnt/dotfiles",
    "DOTGIT": "/mnt/.git",
    "WORKTREE_DIR": "/home/vscode/worktree",
    "WORKTREE_BRANCH": "devcontainer"
  },
  "onCreateCommand": "make -f \"${DOTFILES}\"/devcontainer/Makefile install"
}
