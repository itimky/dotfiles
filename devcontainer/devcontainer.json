{
  "name": "dotfiles",
  "dockerComposeFile": "docker-compose.yaml",
  "service": "devcontainer",
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "openai.chatgpt",
        "vitest.explorer"
      ]
    }
  },
  "workspaceFolder": "/mnt/workspace",
  "containerEnv": {
    "DOTFILES": "/mnt/dotfiles"
  },
  "onCreateCommand": "make -f \"${DOTFILES}\"/devcontainer/Makefile install"
}
