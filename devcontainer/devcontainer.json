{
  "name": "dotfiles",
  "dockerComposeFile": "docker-compose.yaml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "remoteUser": "root",
  "onCreateCommand": "make -C /dotfiles devcontainer-init",
  "postCreateCommand": "make -f /dotfiles/Makefile devcontainer-install",
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "github.copilot-chat",
        "github.vscode-github-actions",
        "openai.chatgpt",
        "vitest.explorer"
      ]
    }
  }
}
